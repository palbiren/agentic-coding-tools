{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "python3 agent-coordinator/scripts/print_coordinator_env.py"
      },
      {
        "type": "command",
        "command": "python3 agent-coordinator/scripts/register_agent.py"
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "python3 agent-coordinator/scripts/report_status.py"
      }
    ],
    "SessionEnd": [
      {
        "type": "command",
        "command": "python3 agent-coordinator/scripts/deregister_agent.py"
      }
    ]
  }
}

# .secrets.yaml — Local secrets for profile interpolation.
# Copy to .secrets.yaml and fill in real values.
# This file is gitignored — never commit the real .secrets.yaml.
#
# When OpenBao is enabled (BAO_ADDR set), secrets are loaded from OpenBao
# instead of this file. Use `make bao-seed` to populate OpenBao from this file.
#
# OpenBao environment variables (set these in .env or shell):
#   BAO_ADDR=http://localhost:8200    # OpenBao server URL (activates OpenBao backend)
#   BAO_ROLE_ID=<role-id>             # AppRole role ID for authentication
#   BAO_SECRET_ID=<secret-id>         # AppRole secret ID for authentication
#   BAO_MOUNT_PATH=secret             # KV v2 mount path (default: secret)
#   BAO_SECRET_PATH=coordinator       # Secret data path (default: coordinator)
#   BAO_TIMEOUT=5                     # Connection timeout in seconds (default: 5)
#   BAO_TOKEN_TTL=3600                # Token TTL in seconds (default: 3600)
#   BAO_TOKEN=<root-token>            # Root token for bao-seed.py only

DB_PASSWORD: postgres
# COORDINATION_API_KEYS is auto-derived from agents.yaml — no need to set it.
CLAUDE_WEB_API_KEY: ""
CODEX_API_KEY: ""
GEMINI_API_KEY: ""

title: 11-Step Worker Execution Protocol (Phase B)
---
graph LR
    B1["B1: Register\n+ Heartbeat"]
    B2["B2: Pause\nCheck"]
    B3["B3: Lock\nAcquire"]
    B4["B4: Port\nAlloc"]
    B5["B5: Read\nDeps"]
    B6["B6: Code\nGen"]
    B7["B7: Scope\nCheck"]
    B8["B8: Verify\nTests"]
    B9["B9: Pause\nRe-check"]
    B10["B10: Publish\nResult"]
    B11["B11: Cleanup"]

    B1 --> B2
    B2 --> B3
    B3 --> B4
    B4 --> B5
    B5 --> B6
    B6 --> B7
    B7 --> B8
    B8 --> B9
    B9 --> B10
    B10 --> B11

    B2 -- "PAUSED" --> WAIT["Wait"]
    WAIT --> B2
    B3 -- "FAIL" --> ESC["Escalate"]
    B7 -- "SCOPE\nVIOLATION" --> ESC
    B8 -- "STUCK" --> CB["Circuit\nBreaker"]
    CB --> ESC

